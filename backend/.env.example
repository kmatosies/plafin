# ==============================================
# Service OS — Variáveis de Ambiente
# ==============================================
# Copie este arquivo para .env e preencha os valores

# --- Supabase ---
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_KEY=sua-chave-anon-aqui
SUPABASE_SERVICE_KEY=sua-chave-service-role-aqui

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXX

# Plano STARTER (mensal)
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly_XXX

# Plano PRO (mensal)
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_XXX

# --- Google Gemini ---
GEMINI_API_KEY=sua-chave-gemini-aqui

# --- Email (SMTP) para notificações ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app
SMTP_FROM=no-reply@serviceos.app

# --- Worker de notificações ---
NOTIFICATION_WORKER_ENABLED=true
NOTIFICATION_WORKER_INTERVAL_SECONDS=60
NOTIFICATION_WORKER_ERROR_BACKOFF_SECONDS=300

# --- WhatsApp (Evolution API) — Plano PRO ---
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua-chave-evolution-aqui
EVOLUTION_INSTANCE=sua-instancia

# --- App ---
APP_NAME=Service OS
FRONTEND_URL=http://localhost:3000
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5173
BACKEND_URL=http://localhost:8000
